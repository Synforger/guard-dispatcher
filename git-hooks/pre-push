#!/usr/bin/env bash
# =============================================================================
# Global pre-push dispatcher
# =============================================================================
# Behaviour:
#   1. If the repo ships `.githooks/pre-push`, run it first (AND — a pass
#      does not skip the baseline below). stdin ref lines are captured
#      once and re-fed to both consumers.
#   2. For enforced (and no-remote fail-safe) repos, parse the captured
#      ref ranges and run `.tooling/local-ci/anon-audit-deep.sh --range` on
#      each outgoing commit range. Missing scanner = hard fail.
#   3. Other repos: only the repo-local hook result applies.
#
# stdin format (per git hooks docs):
#   <local-ref> SP <local-sha> SP <remote-ref> SP <remote-sha> LF
# A remote-sha of all zeros = new branch on the remote.
# A local-sha  of all zeros = branch delete (skipped, no diff to scan).
#
# Range calculation:
#   normal push  — <remote-sha>..<local-sha>
#   new branch   — <nearest-public-base>..<local-sha>
#                  (base = the boundary between the tip and everything
#                   already reachable from the target remote's tracking
#                   refs, so published history is never re-scanned.
#                   Nothing outgoing = skip; no public ancestor at all =
#                   full new-history scan; several attachment points =
#                   origin/<default> approximation as the safe over-scan.)
# =============================================================================
set -eu

# shellcheck source=lib/dispatcher-common.sh
. "$(dirname "$0")/lib/dispatcher-common.sh"

# Capture the ref lines before anything else consumes stdin — both the
# repo-local hook and the baseline loop below need them.
ref_lines="$(cat)"

local_status=0
if [ -n "${ref_lines}" ]; then
    printf '%s\n' "${ref_lines}" | dispatcher::run_local_hook "pre-push" "$@" || local_status=$?
else
    dispatcher::run_local_hook "pre-push" "$@" </dev/null || local_status=$?
fi

kind="$(dispatcher::detect_repo_kind)"
if [ "${kind}" = "other" ] || [ "${kind}" = "exempt" ]; then
    exit "${local_status}"
fi

scanner="$(dispatcher::locate_deep_scanner || true)"
if [ -z "${scanner}" ]; then
    cat >&2 <<'MSG'
[pre-push] anon-audit-deep.sh could not be resolved (repo-local or guard
           bundled). The guard checkout is likely missing or moved —
           re-run its install.sh from a healthy checkout.
MSG
    exit 1
fi

zero='0000000000000000000000000000000000000000'
remote_name="${1:-origin}"
default_branch="$(dispatcher::default_branch)"
allowed_emails="$(dispatcher::allowed_emails)"
any_leak=0

# Iterate the captured ref lines. An empty push (no matching refspec)
# just falls through.
while read -r local_ref local_sha remote_ref remote_sha; do
    [ -z "${local_ref}" ] && continue

    # delete push — nothing outgoing to scan
    if [ "${local_sha}" = "${zero}" ]; then
        continue
    fi

    # Protected-branch guard: PR merges happen server-side, so a direct
    # local push to main/develop is a process violation. The initial push
    # that creates the branch on the remote is the one legitimate case.
    # GUARD_ALLOW_PROTECTED_PUSH=1 is the audited escape hatch.
    if dispatcher::protected_branch "${remote_ref}" \
        && [ "${remote_sha}" != "${zero}" ] \
        && [ "${GUARD_ALLOW_PROTECTED_PUSH:-0}" != "1" ]; then
        printf '[pre-push] direct push to %s refused (use a PR; set GUARD_ALLOW_PROTECTED_PUSH=1 to override once)\n' "${remote_ref}" >&2
        any_leak=1
        continue
    fi

    # Ref-name scan: a branch or tag name is published as-is on the remote,
    # so it crosses the same boundary as file content.
    ref_tmp="$(mktemp)"
    printf '%s\n' "${local_ref}" > "${ref_tmp}"
    if ! ANON_SCAN_PATHS="${ref_tmp}" bash "$(dispatcher::locate_anon_scanner)" >/dev/null 2>&1; then
        printf '[pre-push] ref name %s matches the word list — rename the branch/tag before pushing\n' "${local_ref}" >&2
        rm -f "${ref_tmp}"
        any_leak=1
        continue
    fi
    rm -f "${ref_tmp}"

    if [ "${remote_sha}" = "${zero}" ]; then
        # New remote branch — scan only the truly-outgoing commits, i.e.
        # those not already reachable from any tracking ref of the target
        # remote. Ranging from origin/<default> instead would re-scan
        # published history forever under a squash-merge flow (commits
        # between the default branch and a feature tip never become
        # ancestors of the default branch), tripping the audit on every
        # new branch even when the actual delta is clean.
        outgoing_count="$(git rev-list --count "${local_sha}" --not --remotes="${remote_name}" 2>/dev/null || echo 0)"
        if [ "${outgoing_count}" -eq 0 ]; then
            # Tip is already reachable on the remote — nothing outgoing.
            continue
        fi
        bases="$(git rev-list --boundary "${local_sha}" --not --remotes="${remote_name}" 2>/dev/null | sed -n 's/^-//p' | sort -u)"
        base_count="$(printf '%s' "${bases}" | grep -c . || true)"
        if [ "${base_count}" -eq 1 ]; then
            # Exactly one public attachment point — express it as the
            # two-dot range the scanners (and anon-fix) understand.
            revspec="${bases}..${local_sha}"
        elif [ "${base_count}" -eq 0 ]; then
            # Nothing reachable is public (fresh or disjoint history) —
            # scan the entire new history (safe side).
            revspec="${local_sha}"
        else
            # Multiple public attachment points (a merge of published
            # lines): a two-dot range cannot express the exact outgoing
            # set, so keep the default-branch approximation as the safe
            # over-scan.
            revspec="origin/${default_branch}..${local_sha}"
            if ! git rev-parse "origin/${default_branch}" >/dev/null 2>&1; then
                revspec="${local_sha}"
            fi
        fi
    else
        if git rev-parse --verify "${remote_sha}^{commit}" >/dev/null 2>&1; then
            revspec="${remote_sha}..${local_sha}"
        else
            # Force-push after a history rewrite: the old remote tip no
            # longer exists locally, so a two-dot range cannot be built.
            # Scan the entire new history instead (safe side — this is
            # exactly the moment a scrub is being published).
            revspec="${local_sha}"
        fi
    fi

    # Identity check over the outgoing commits: every author and committer
    # must be the expected public identity for this machine's enforced org.
    bad_ids="$(git log "${revspec}" --pretty='format:%ae%n%ce' 2>/dev/null | sort -u | grep -Fxvf <(printf '%s\n' "${allowed_emails}") || true)"
    if [ -n "${bad_ids}" ]; then
        printf '[pre-push] unexpected author/committer in outgoing range %s:\n' "${revspec}" >&2
        printf '%s\n' "${bad_ids}" | sed 's/^/    /' >&2
        printf '           allowed identities:\n' >&2
        printf '%s\n' "${allowed_emails}" | sed 's/^/    /' >&2
        any_leak=1
        continue
    fi

    printf '[pre-push] anon-audit-deep --range %s (ref %s)\n' "${revspec}" "${local_ref}" >&2
    if ! bash "${scanner}" --range "${revspec}"; then
        # Try to self-heal only when the operator opted in — a silent
        # filter-repo pass on every push would be too surprising, and it
        # can't undo a mis-scoped rewrite.
        fixer="$(dispatcher::locate_scanner "anon-fix.sh" || true)"
        if [ "${ANON_FIX_AUTO:-0}" = "1" ] && [ -n "${fixer}" ]; then
            echo "[pre-push] ANON_FIX_AUTO=1 — running anon-fix.sh --auto..." >&2
            if bash "${fixer}" --range "${revspec}" --auto; then
                echo "[pre-push] anon-fix succeeded; push proceeds." >&2
                continue
            fi
            echo "[pre-push] anon-fix failed — refusing push." >&2
            any_leak=1
        else
            cat >&2 <<HINT

To scrub the leak in place before push (rewrites the outgoing range
so the public record shows neither the leak nor a repair scar):

    bash ${fixer:-<guard>/scanners/anon-fix.sh} --range ${revspec}

Or export ANON_FIX_AUTO=1 to have this hook do it for you automatically.
HINT
            any_leak=1
        fi
    fi
done <<EOF_REFS
${ref_lines}
EOF_REFS

if [ "${any_leak}" -ne 0 ]; then
    exit 1
fi
exit "${local_status}"
