#!/usr/bin/env bash
# =============================================================================
# Global pre-commit dispatcher
# =============================================================================
# Behaviour (AND-composition):
#   1. If the repo ships `.githooks/pre-commit`, run it first — a failing
#      local hook fails the commit, but a passing one does NOT skip the
#      baseline below. Repo hooks add rules; they never replace the guard.
#   2. On enforced repos (org-matched or no-remote fail-safe), scan staged
#      files with the anon scanner (repo-local override or the bundled
#      copy). Unresolvable scanner = hard fail.
#   3. On all other repos, only the repo-local hook result applies.
#
# The dispatcher never invents anon policy of its own — the source of truth
# lives in each repo's `.tooling/local-ci/anon-scan.sh` + `anon-words.txt`.
# =============================================================================
set -eu

# shellcheck source=lib/dispatcher-common.sh
. "$(dirname "$0")/lib/dispatcher-common.sh"

local_status=0
dispatcher::run_local_hook "pre-commit" "$@" || local_status=$?

kind="$(dispatcher::detect_repo_kind)"
case "${kind}" in
    other|exempt)
        exit "${local_status}"
        ;;
    synforger|no-remote|enforced)
        # Fresh repos with no remote are treated as if they might become
        # Synforger repos — fail safe rather than skip the scan. `enforced`
        # is the machine-side opt-in (guard.scope, see dispatcher-common.sh).
        ;;
esac

# Identity check: an enforced repo committing under any other email is an
# identity mix-up (usually a forgotten per-repo git config after a fresh
# clone) — block it before the commit exists.
actual_email="$(git config user.email 2>/dev/null || true)"
if ! dispatcher::allowed_emails | grep -Fxq "${actual_email}"; then
    {
        echo "[pre-commit] identity mismatch on an enforced repo."
        echo "             user.email = ${actual_email:-<unset>}"
        echo "             allowed:"
        dispatcher::allowed_emails | sed 's/^/               /'
        echo "             Fix: git config user.email <one of the above>"
    } >&2
    exit 1
fi

scanner="$(dispatcher::locate_anon_scanner || true)"
if [ -z "${scanner}" ]; then
    cat >&2 <<'MSG'
[pre-commit] anon-scan.sh could not be resolved.
             Lookup order: <repo>/.tooling/local-ci/anon-scan.sh, then the
             guard-dispatcher checkout's scanners/ directory. Neither was
             found — the guard checkout is likely missing or moved. Re-run
             guard-dispatcher's install.sh from a healthy checkout.
MSG
    exit 1
fi

staged="$(git diff --cached --name-only --diff-filter=ACMRT)"
if [ -z "${staged}" ]; then
    exit "${local_status}"
fi

repo_root="$(git rev-parse --show-toplevel)"
abs_paths=""
while IFS= read -r rel; do
    [ -z "${rel}" ] && continue
    abs_paths="${abs_paths}${repo_root}/${rel}
"
done <<EOF
${staged}
EOF

if ! ANON_SCAN_PATHS="${abs_paths}" bash "${scanner}"; then
    exit 1
fi
exit "${local_status}"
